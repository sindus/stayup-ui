# ─── App ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change_me_to_a_random_32_char_string_minimum
BETTER_AUTH_URL=http://localhost:3001

# ─── Database (auth only — PostgreSQL on port 5433) ───────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/stayup_auth

# ─── OAuth providers ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── External API (stayup-api) ────────────────────────────────────────
# Used server-side (API routes, Server Components)
STAYUP_API_URL=http://localhost:3000
# Used client-side (browser fetch)
NEXT_PUBLIC_STAYUP_API_URL=http://localhost:3000
